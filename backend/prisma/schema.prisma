generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model comments {
  id      Int      @id @default(autoincrement())
  name    String   @db.VarChar(255)
  content String   @db.VarChar(255)
  date    DateTime @db.Timestamptz(6)
  post_id Int?
  posts   posts?   @relation(fields: [post_id], references: [id], onDelete: Cascade)
}

model images {
  id          Int           @id @default(autoincrement())
  image_url   String        @db.VarChar(255)
  created_at  DateTime      @db.Timestamptz(6)
  updated_at  DateTime      @db.Timestamptz(6)
  post_images post_images[]
}

model post_images {
  id          Int      @id @default(autoincrement())
  post_id     Int
  image_id    Int
  is_featured Boolean? @default(false)
  order       Int?     @default(0)
  images      images   @relation(fields: [image_id], references: [id], onDelete: Cascade)
  posts       posts    @relation(fields: [post_id], references: [id], onDelete: Cascade)

  @@unique([post_id, image_id], map: "post_images_post_id_image_id")
  @@unique([post_id, image_id])
}

model post_tags {
  post_id Int
  tag_id  Int
  posts   posts @relation(fields: [post_id], references: [id], onDelete: Cascade)
  tags    tags  @relation(fields: [tag_id], references: [id], onDelete: Cascade)

  @@id([post_id, tag_id])
}

model posts {
  id          Int           @id @default(autoincrement())
  title       String        @db.VarChar(255)
  content     String
  date        DateTime      @db.Timestamptz(6)
  comments    comments[]
  post_images post_images[]
  post_tags   post_tags[]
}

model tags {
  id        Int         @id @default(autoincrement())
  name      String      @unique @db.VarChar(255)
  post_tags post_tags[]
}
